fancybox/helpers/fancybox_buttons.png","shasum":"e385b139516c6813dcd64b8fc431c364ceafe5f3","modified":1454788141999},{"_id":"themes/bootstrap-blog/source/fancybox/helpers/jquery.fancybox-buttons.css","shasum":"6394c48092085788a8c0ef72670b0652006231a1","modified":1454788142000},{"_id":"themes/bootstrap-blog/source/fancybox/helpers/jquery.fancybox-buttons.js","shasum":"4c9c395d705d22af7da06870d18f434e2a2eeaf9","modified":1454788142000},{"_id":"themes/bootstrap-blog/source/fancybox/helpers/jquery.fancybox-media.js","shasum":"e14c32cc6823b81b2f758512f13ed8eb9ef2b454","modified":1454788142001},{"_id":"themes/bootstrap-blog/source/fancybox/helpers/jquery.fancybox-thumbs.css","shasum":"b88b589f5f1aa1b3d87cc7eef34c281ff749b1ae","modified":1454788142002},{"_id":"themes/bootstrap-blog/source/fancybox/helpers/jquery.fancybox-thumbs.js","shasum":"83cdfea43632b613771691a11f56f99d85fb6dbd","modified":1454788142003},{"_id":"themes/bootstrap-blog/source/fancybox/jquery.fancybox.css","shasum":"2e54d51d21e68ebc4bb870f6e57d3bfb660d4f9c","modified":1454788142004},{"_id":"themes/bootstrap-blog/source/fancybox/jquery.fancybox.js","shasum":"58193c802f307ec9bc9e586c0e8a13ebef45d2f8","modified":1454788142015},{"_id":"themes/bootstrap-blog/source/fancybox/jquery.fancybox.pack.js","shasum":"2da892a02778236b64076e5e8802ef0566e1d9e8","modified":1454788142025},{"_id":"themes/bootstrap-blog/source/js/script.js","shasum":"0f5f799f3d059fa56a3eddd3d1eb5236e636e12d","modified":1454788142030},{"_id":"public/2016/02/06/DateTime2/index.html","modified":1455194936012,"shasum":"9b5119c8bd20f19d1f0e77ae2818382f8fcdc3e2"},{"_id":"public/archives/index.html","modified":1455194936027,"shasum":"4894c9402a38831376daaae2ccdc4b4a709ac9da"},{"_id":"public/archives/2016/index.html","modified":1455194936043,"shasum":"b6539435bde1b31903cf87e609b7cf01b6a203cc"},{"_id":"public/archives/2016/02/index.html","modified":1455194936064,"shasum":"f90db975a7940f9161dc3147abf296503d3d4220"},{"_id":"public/index.html","modified":1455194936065,"shasum":"96db6a525681070122b1c8e6d1c0a89f9dfcde4b"},{"_id":"public/tags/SQL-Server/index.html","modified":1455194936081,"shasum":"7f97d3eeb84ffae6d1edca99cad2cd09b35057d7"},{"_id":"public/tags/Data-Types/index.html","modified":1455194936096,"shasum":"b8a73d2bc1cb4f75c12ce0d55da58b8887b024df"},{"_id":"public/tags/DateTime/index.html","modified":1455194936112,"shasum":"f37ec3fc57ee832e4971adb89fd91f6a546ef446"},{"_id":"public/tags/Best-Practices/index.html","modified":1455194936112,"shasum":"220900b71a95e206a625e36efd796beaf4f60ff3"}],"Category":[],"Data":[],"Page":[],"Post":[{"title":"Which Datetime Data Type?","date":"2016-02-06T20:08:02.000Z","_content":"\nWhen I took over a database recently (ok almost 2 years ago now), one of the first things I noticed was that the previous \"developers\" made heavy use of datetime2:\n\n{% codeblock %}\ndeclare @salesTime datetime2(7)\n{% endcodeblock %}\n\nJust to be clear, this is data for a point-of sale system and the date is being stored with a precision of 7(!) digits of precision per second.  The 10th of a microsecond. That's 2007/02/07 16:01:23.1234567!  Or as I like to joke that we know the microsecond Jesus made his purchase!\n\nBeginning in SQL Server 2008, Microsoft added a new datetime data type of datetime2.  At the time most of my experience had been with SQL Server 2000 and 2005 and the only options for storing a datetime in SQL Server were datetime and smalldatetime which had fixed precision and storage values.  This meant that if your application needed dates far into the future or precision beyond a minute, you had no choice but to double your storage size. \n\nA brief look at each data type:\n\n|Type | Range | Precision | Storage (bytes)\t| Fixed size? |\n| - | - | - | - | - |\n|smalldatetime | 1900-01-01 to 2079-06-06 | 1 minute | 4 | Yes |\n|datetime | 1753-01-01 to 9999-12-31 | .00333 seconds |\t8 |\tYes |\n|datetime2(*n*) | 0001-01-01 to 9999-12-31 23:59.59.9999999 | 100 ns | 6-8 | No |\n|date |\t0001-01-01 to 9999-12-31 | 1 day | 3 | Yes |\n|time(*n*) |\t00:00:00.0000000 to 23:59.59.9999999 | 100 ns |\t3-5\t| No |\n\nCurrent SQL Server 2008/2012/2014 recommendations are to use datetime2, date, and time types for you schema and use the lowest precision possible.  For the point-of-sale application mentioned above, I can easily settle for knowing to the second when an event took place.  With storage being so cheap, the difference between a couple of bytes might not make a lot of sense but the difference in those bytes over thousands or millions of rows and their impact on performance tuning.  If you only need to store the date, then just use the date data type which will store the date without the time and can greatly simply searches where the time of day isn't important.\n\nDatetime is now deprecated but don't go too far with the precision of datetime2 unless needed. Up to 2 bytes of saving per column may seem minimal but small savings add up as applications grow in scale and what's the point of storing data that you don't need and will never use. \n\n\n","source":"_posts/2016-02-06-DateTime2.md","raw":"---\ntitle: Which Datetime Data Type?\ndate: 2016-02-06 15:08:02\ntags:  \n\t- SQL Server\n\t- Data Types\n\t- DateTime\n\t- Best Practices\n---\n\nWhen I took over a database recently (ok almost 2 years ago now), one of the first things I noticed was that the previous \"developers\" made heavy use of datetime2:\n\n{% codeblock %}\ndeclare @salesTime datetime2(7)\n{% endcodeblock %}\n\nJust to be clear, this is data for a point-of sale system and the date is being stored with a precision of 7(!) digits of precision per second.  The 10th of a microsecond. That's 2007/02/07 16:01:23.1234567!  Or as I like to joke that we know the microsecond Jesus made his purchase!\n\nBeginning in SQL Server 2008, Microsoft added a new datetime data type of datetime2.  At the time most of my experience had been with SQL Server 2000 and 2005 and the only options for storing a datetime in SQL Server were datetime and smalldatetime which had fixed precision and storage values.  This meant that if your application needed dates far into the future or precision beyond a minute, you had no choice but to double your storage size. \n\nA brief look at each data type:\n\n|Type | Range | Precision | Storage (bytes)\t| Fixed size? |\n| - | - | - | - | - |\n|smalldatetime | 1900-01-01 to 2079-06-06 | 1 minute | 4 | Yes |\n|datetime | 1753-01-01 to 9999-12-31 | .00333 seconds |\t8 |\tYes |\n|datetime2(*n*) | 0001-01-01 to 9999-12-31 23:59.59.9999999 | 100 ns | 6-8 | No |\n|date |\t0001-01-01 to 9999-12-31 | 1 day | 3 | Yes |\n|time(*n*) |\t00:00:00.0000000 to 23:59.59.9999999 | 100 ns |\t3-5\t| No |\n\nCurrent SQL Server 2008/2012/2014 recommendations are to use datetime2, date, and time types for you schema and use the lowest precision possible.  For the point-of-sale application mentioned above, I can easily settle for knowing to the second when an event took place.  With storage being so cheap, the difference between a couple of bytes might not make a lot of sense but the difference in those bytes over thousands or millions of rows and their impact on performance tuning.  If you only need to store the date, then just use the date data type which will store the date without the time and can greatly simply searches where the time of day isn't important.\n\nDatetime is now deprecated but don't go too far with the precision of datetime2 unless needed. Up to 2 bytes of saving per column may seem minimal but small savings add up as applications grow in scale and what's the point of storing data that you don't need and will never use. \n\n\n","slug":"DateTime2","published":1,"updated":"2016-02-11T01:30:49.327Z","comments":1,"layout":"post","photos":[],"link":"","_id":"cikhn8tvi000060wkyrdh6pwa"}],"PostAsset":[],"PostCategory":[],"PostTag":[{"post_id":"cikhn8tvi000060wkyrdh6pwa","tag_id":"cikhn8tvy000160wkhfgx7esp","_id":"cikhn8tvy000560wklwclj7pd"},{"post_id":"cikhn8tvi000060wkyrdh6pwa","tag_id":"cikhn8tvy000260wkq0mhdgxj","_id":"cikhn8tvy000660wk6910ow3g"},{"post_id":"cikhn8tvi000060wkyrdh6pwa","tag_id":"cikhn8tvy000360wkbff4m5pv","_id":"cikhn8tvy000760wkdlc0nqzj"},{"post_id":"cikhn8tvi000060wkyrdh6pwa","tag_id":"cikhn8tvy000460wkpqwe4o8t","_id":"cikhn8tvy000860wkgtzpk5ub"}],"Tag":[{"name":"SQL Server","_id":"cikhn8tvy000160wkhfgx7esp"},{"name":"Data Types","_id":"cikhn8tvy000260wkq0mhdgxj"},{"name":"DateTime","_id":"cikhn8tvy000360wkbff4m5pv"},{"name":"Best Practices","_id":"cikhn8tvy000460wkpqwe4o8t"}]}}